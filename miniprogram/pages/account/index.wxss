.hero{padding:30rpx;background:linear-gradient(145deg,#fff,#fff0df)}.hero-top{display:flex;align-items:flex-start;justify-content:space-between;gap:20rpx}.profile-mini{display:flex;align-items:center;gap:18rpx;margin-top:22rpx}.avatar{width:88rpx;height:88rpx;border-radius:28rpx;background:#ff7622;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;box-shadow:0 12rpx 30rpx rgba(255,122,34,.16)}.profile-copy{min-width:0}.profile-name{font-size:34rpx;font-weight:900;color:#1f1814}.profile-copy text{display:block;margin-top:6rpx;color:#8b7a6f;font-size:23rpx}.hero-actions{display:flex;gap:12rpx;flex-wrap:wrap;margin-top:22rpx}.hero-actions button,.ghost,.secondary,.primary,.danger{border-radius:999rpx;font-size:24rpx;line-height:1;padding:16rpx 22rpx}.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16rpx;margin-top:24rpx}.stat{padding:24rpx 18rpx;text-align:center}.stat text{display:block;color:#8b7a6f;font-size:22rpx}.stat view{margin-top:8rpx;font-size:40rpx;font-weight:900;color:#1f1814}.section{margin-top:20rpx}.section-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16rpx}.section-title{font-size:32rpx;font-weight:900;color:#1f1814;margin-top:6rpx}.pet-meta{margin-top:14rpx;color:#6f6054;font-size:24rpx;line-height:1.7}.portrait-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14rpx;margin-top:18rpx}.portrait-item{border-radius:24rpx;overflow:hidden;background:#fff7ef}.portrait-item image{width:100%;height:220rpx}.portrait-meta{padding:14rpx 16rpx}.portrait-meta view{font-size:24rpx;font-weight:800;color:#1f1814}.portrait-meta text{display:block;margin-top:6rpx;color:#8b7a6f;font-size:22rpx}.history-list{margin-top:16rpx;display:flex;flex-direction:column;gap:14rpx}.history-item{padding:18rpx;border:1rpx solid #f0e0d2;border-radius:24rpx;background:#fff}.history-main{display:flex;align-items:center;justify-content:space-between;gap:16rpx}.history-name{font-size:28rpx;font-weight:800;color:#1f1814}.history-main text{display:block;margin-top:6rpx;color:#8b7a6f;font-size:22rpx}.empty-block{padding:36rpx 18rpx;color:#8b7a6f;font-size:24rpx;line-height:1.7;text-align:center;background:#fff9f2;border-radius:24rpx;margin-top:16rpx}.ghost{background:#fff;color:#4f463f;border:1rpx solid #ead9ca}.secondary{background:#fff7ef;color:#ff7622;border:1rpx solid #ffd7b7}.primary{background:#ff7622;color:#fff;border:0}.danger{background:#7d2d1e;color:#fff;border:0}.danger-text{background:#fff;color:#b5482e;border:1rpx solid #e7b7aa}.muted{color:#8a796c;font-size:22rpx}.ad-slot{margin:24rpx 0 0}
@media (max-width: 800rpx){.stats-grid{grid-template-columns:1fr}.portrait-grid{grid-template-columns:1fr}}
