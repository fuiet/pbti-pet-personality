.page {
  padding: 24rpx;
  background: #fff8ef;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.eyebrow,
.section-title {
  color: #ff7622;
  font-weight: 700;
  font-size: 24rpx;
}

.title {
  margin-top: 16rpx;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.1;
}

.subtitle {
  margin-top: 16rpx;
  color: #6f6157;
  line-height: 1.8;
}

.stats,
.quick-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.stats view {
  flex: 1;
  text-align: center;
  background: #fff8f1;
  border-radius: 22rpx;
  padding: 22rpx 12rpx;
}

.stats text {
  display: block;
  color: #ff7622;
  font-size: 42rpx;
  font-weight: 800;
}

.stats view view {
  margin-top: 6rpx;
  color: #7a6d63;
  font-size: 22rpx;
}

.quick-grid {
  flex-wrap: wrap;
}

.quick {
  flex: 1;
  min-width: 200rpx;
  background: #ff7622;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.report-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.report-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #171514;
}

.report-meta {
  margin-top: 8rpx;
  color: #7a6d63;
  font-size: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty text {
  color: #6f6157;
  line-height: 1.8;
}
