<view class="page">
  <view class="hero card">
    <text class="eyebrow">PBTI 仪表盘</text>
    <view class="title">快速查看你的宠物性格进度</view>
    <view class="subtitle">这里会展示最近的测试结果、写真数量和下一步入口，方便你快速回到当前工作流。</view>
    <view class="stats">
      <view><text>{{history.length}}</text><view>最近报告</view></view>
      <view><text>{{petCount}}</text><view>已分析宠物</view></view>
      <view><text>{{portraitCount}}</text><view>写真数量</view></view>
    </view>
  </view>

  <view class="section-title">快捷入口</view>
  <view class="quick-grid">
    <button class="quick" bindtap="goCreate">开始新测试</button>
    <button class="quick" bindtap="goTypes">查看性格图鉴</button>
    <button class="quick" bindtap="goAccount">进入我的页面</button>
  </view>

  <view class="section-title">最近报告</view>
  <view wx:if="{{history.length}}" class="report-list">
    <view class="report card" wx:for="{{history}}" wx:key="id" data-i="{{index}}" bindtap="openReport">
      <view class="report-title">{{item.pet.name}} · {{item.result.personality.name}}</view>
      <view class="report-meta">{{item.result.code}} · {{item.result.personality.title}}</view>
    </view>
  </view>

  <view wx:else class="card empty">
    <view class="empty-title">还没有报告</view>
    <text>先完成一次测试，仪表盘就会自动显示最近结果。</text>
  </view>
</view>
