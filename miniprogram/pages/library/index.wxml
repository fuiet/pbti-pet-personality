<view class="page">
 <view class="title small">写真作品库</view>
 <view class="subtitle">生成过的宠物写真会保存在这里。</view>
 <view class="subtitle source-tip">当前来源：{{source === 'cloud' ? '云端作品库' : '本地作品库'}}</view>

 <view wx:if="{{!items.length}}" class="empty card">
  <view class="empty-title">还没有作品</view>
  <text>完成第一张 AI 写真后，它会出现在这里。</text>
 </view>

 <view class="grid">
  <view class="work card" wx:for="{{items}}" wx:key="id" data-i="{{index}}">
   <view data-url="{{item.url}}" bindtap="preview">
   <image src="{{item.url}}" mode="aspectFill"/>
   <view class="work-body">
    <view class="work-title">{{item.petName}} · {{item.template}}</view>
    <text>{{item.code}} · {{item.personality}}</text>
    <text>{{item.createdLabel}}</text>
    <text wx:if="{{item.prompt !== '未补充描述'}}">{{item.prompt}}</text>
   </view>
   </view>
   <button class="delete-btn" data-i="{{index}}" bindtap="remove">删除写真</button>
  </view>
 </view>
</view>
