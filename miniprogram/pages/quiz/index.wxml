<view class="page quiz" wx:if="{{currentQuestion}}">
 <view class="between">
  <text class="eyebrow">第 {{index + 1}} / 28 题</text>
  <text class="muted">{{currentQuestion.dimension}}</text>
 </view>
 <view class="bar"><view style="width:{{progress}}%"></view></view>

 <view class="question">{{currentQuestion.question}}</view>
 <view class="options">
  <view class="option {{selected===item.value?'selected':''}}" wx:for="{{currentQuestion.options}}" wx:key="text" data-value="{{item.value}}" bindtap="answer">
   <text>{{optionTags[index]}}</text>
   <view class="option-text">{{item.text}}</view>
  </view>
 </view>

 <button wx:if="{{index>0}}" class="secondary prev" bindtap="prev">上一题</button>
 <view class="privacy">请选择最符合最近 1 个月日常表现的答案</view>
</view>
