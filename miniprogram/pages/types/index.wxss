.page{padding:24rpx;background:#fff8ef;min-height:100vh}.card{background:#fff;border-radius:32rpx;padding:30rpx;box-shadow:0 18rpx 48rpx rgba(93,55,25,.08);margin-bottom:24rpx}.hero{padding-bottom:24rpx;background:linear-gradient(180deg,#fff 0%,#fff9f2 100%)}.hero-logo{width:140rpx;height:52rpx;margin-bottom:18rpx}.eyebrow,.section-title{color:#ff7622;font-weight:900;font-size:22rpx;letter-spacing:3rpx}.title{margin-top:16rpx;font-size:46rpx;font-weight:900;line-height:1.08;letter-spacing:-1rpx}.subtitle{margin-top:16rpx;color:#6f6157;line-height:1.8}.species-switch{display:flex;gap:16rpx;margin-top:24rpx}.species-switch button,.primary{border-radius:999rpx;padding:18rpx 28rpx;font-size:28rpx;line-height:1}.species-switch button{background:#f6efe6;color:#5d5248}.species-switch .active{background:#ff7622;color:#fff}.type-list{display:grid;grid-template-columns:1fr 1fr;gap:16rpx}.type-card{border:1rpx solid #f0e0d2;overflow:hidden}.type-image-wrap{position:relative;border-radius:24rpx;background:#fff9f2;padding:18rpx 12rpx 10rpx;overflow:hidden}.type-image{width:100%;height:190rpx}.species-tag{position:absolute;right:16rpx;top:16rpx;padding:10rpx 14rpx;border-radius:999rpx;background:rgba(255,255,255,.88);color:#8b6b52;font-size:20rpx;font-weight:800}.type-head{display:flex;justify-content:space-between;gap:20rpx;align-items:flex-start;margin-top:14rpx}.type-code{color:#ff7622;font-size:32rpx;font-weight:900}.type-name{margin-top:6rpx;font-size:28rpx;font-weight:800}.type-tone,.type-trait,.type-care{margin-top:12rpx;color:#5f544a;line-height:1.65;font-size:24rpx}.type-trait{color:#3f352e}.notice-title{font-size:32rpx;font-weight:700;margin-bottom:12rpx}.notice text{display:block;color:#6f6157;line-height:1.8;margin-bottom:20rpx}.primary{width:100%;background:#ff7622;color:#fff}
