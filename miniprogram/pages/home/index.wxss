.custom-nav{height:96rpx;display:flex;align-items:center;justify-content:center;padding-top:env(safe-area-inset-top)}.nav-logo{width:160rpx;height:58rpx;object-fit:contain}.hero{padding:30rpx 30rpx 36rpx;background:linear-gradient(145deg,#fff,#fff0df);overflow:hidden}.brand{display:flex;align-items:center;gap:18rpx}.brand-copy{flex:1;min-width:0}.title{margin-top:18rpx;white-space:pre-line}.hero-art{margin:18rpx 0 8rpx;display:flex;justify-content:center;align-items:center}.hero-art image{width:100%;height:360rpx}.subtitle{margin-top:18rpx}.actions{display:flex;flex-direction:column;gap:14rpx;margin-top:24rpx}.start,.secondary{height:88rpx;line-height:88rpx}.secondary{background:#fff7ef;color:#ff7622;border:1rpx solid #ffd7b7}.facts{display:flex;justify-content:space-around;margin-top:28rpx;padding-top:24rpx;border-top:1rpx solid #eedbca}.facts view{display:flex;flex-direction:column;text-align:center}.facts text{font-size:42rpx;font-weight:900;color:#ff7622}.section-title{margin:44rpx 0 20rpx}.type-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx}.type{padding:18rpx;box-sizing:border-box;display:flex;flex-direction:column;align-items:center;text-align:center}.type-image{width:100%;height:180rpx;margin-bottom:8rpx}.type text{font-size:18rpx;color:#ff7622;font-weight:900}.type-name{margin-top:8rpx;font-size:26rpx;font-weight:900}.notice{margin-top:36rpx}.notice text{display:block;margin-top:14rpx;color:#85766b;font-size:25rpx;line-height:1.7}
