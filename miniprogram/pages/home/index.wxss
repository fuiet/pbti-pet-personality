.page {
  min-height: 100vh;
  padding: 40rpx;
}

.hero {
  padding: 44rpx 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.06);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
}

.subtitle {
  display: block;
  margin-top: 20rpx;
  color: #777;
  line-height: 1.7;
}

.actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.primary,
.ghost {
  border-radius: 999rpx;
}

.primary {
  background: #ff7a1a;
  color: #fff;
}

.ghost {
  background: #fff;
  color: #111;
}
