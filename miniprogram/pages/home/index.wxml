<view class="page">
 <view class="custom-nav">
  <image class="nav-logo" src="{{logoImage}}" mode="aspectFit"/>
 </view>
 <view class="hero card">
  <view class="brand">
   <view class="brand-copy">
    <text class="eyebrow">宠物性格测试</text>
    <view class="title">读懂它的性格，把爱给得更准确</view>
   </view>
  </view>
  <view class="hero-art">
   <image src="{{heroImage}}" mode="aspectFit"/>
  </view>
  <view class="subtitle">通过 28 个日常行为问题，发现猫咪或狗狗的 PBTI 性格类型，并获得专属相处建议。</view>
  <view class="actions">
   <button class="primary start" bindtap="start">开始免费测试</button>
   <button class="secondary" bindtap="openTypes">查看图鉴</button>
   <button class="secondary" bindtap="openAbout">说明与常见问题</button>
  </view>
  <view class="facts">
   <view><text>28</text><view>道行为题</view></view>
   <view><text>12</text><view>种性格</view></view>
   <view><text>10</text><view>章报告</view></view>
  </view>
 </view>

 <view class="section-title">12 种宠物性格</view>
 <view class="type-grid">
  <view class="type card" wx:for="{{types}}" wx:key="code">
   <image class="type-image" src="{{item.image}}" mode="aspectFit"/>
   <text>{{item.code}}</text>
   <view class="type-name">{{item.name}}</view>
  </view>
 </view>

 <view class="ad-slot">广告展示位 · 接入流量主后自动展示</view>
 <view class="card notice">
  <view class="notice-title">不是诊断，是更好的观察方式</view>
  <text>结果来自主人对日常行为的观察，仅用于养宠教育与互动参考，不替代兽医建议。</text>
 </view>
</view>
