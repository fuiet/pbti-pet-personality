<view class="page">
 <text class="eyebrow">第 1 步</text>
 <view class="title small">先认识一下你的宠物</view>
 <view class="subtitle">这些资料会用于生成更贴近它的性格报告。</view>

 <view class="card form">
  <text class="label">它是</text>
  <view class="species">
   <view class="choice {{species==='dog'?'active':''}}" data-value="dog" bindtap="chooseSpecies">🐶<text>狗狗</text></view>
   <view class="choice {{species==='cat'?'active':''}}" data-value="cat" bindtap="chooseSpecies">🐱<text>猫咪</text></view>
  </view>

  <text class="label">名字 *</text>
  <input value="{{name}}" data-key="name" bindinput="field" placeholder="例如：麻薯" />

  <text class="label">品种</text>
  <input value="{{breed}}" data-key="breed" bindinput="field" placeholder="例如：柴犬、英短或混血" />

  <view class="columns">
   <view>
    <text class="label">年龄</text>
    <input value="{{age}}" data-key="age" bindinput="field" type="digit" placeholder="岁" />
   </view>
   <view>
    <text class="label">性别（选填）</text>
    <view class="gender">
     <text class="{{gender==='公'?'on':''}}" data-value="公" bindtap="chooseGender">公</text>
     <text class="{{gender==='母'?'on':''}}" data-value="母" bindtap="chooseGender">母</text>
    </view>
   </view>
  </view>
 </view>

 <button class="primary next" bindtap="next">下一步：添加照片</button>
</view>
