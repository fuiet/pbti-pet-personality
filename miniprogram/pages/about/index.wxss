.page {
  padding: 24rpx;
  background: #fff8ef;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.eyebrow,
.section-title {
  color: #ff7622;
  font-weight: 700;
  font-size: 24rpx;
}

.title {
  margin-top: 16rpx;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.1;
}

.subtitle {
  margin-top: 16rpx;
  color: #6f6157;
  line-height: 1.8;
}

.step-title,
.qa-q {
  font-weight: 700;
  font-size: 30rpx;
  color: #171514;
}

.step text,
.qa text,
.notice text {
  display: block;
  margin-top: 12rpx;
  color: #6f6157;
  line-height: 1.8;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.primary,
.secondary {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary {
  background: #ff7622;
  color: #fff;
}

.secondary {
  background: #fff7ef;
  color: #ff7622;
  border: 1rpx solid #ffd7b7;
}
