.hero {
  padding: 30rpx 30rpx 24rpx;
  background: linear-gradient(145deg, #fff, #fff0df);
  overflow: hidden;
}

.heading {
  margin-top: 10rpx;
}

.link {
  color: #ff7622;
  font-weight: 800;
}

.mode-switch {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  padding: 8rpx;
  background: #f3f0eb;
  border-radius: 999rpx;
}

.mode-switch button,
.toggle,
.species-toggle button {
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  line-height: 1;
  background: transparent;
  color: #6f6054;
}

.mode-switch .on,
.species-toggle .on {
  background: #fff;
  color: #ff7622;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 34, 0.12);
  font-weight: 800;
}

.mode-hint {
  margin-top: 18rpx;
  color: #6f6054;
  font-size: 24rpx;
  line-height: 1.7;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 0.9fr;
  gap: 24rpx;
  margin-top: 24rpx;
}

.left,
.right {
  min-width: 0;
}

.panel {
  margin-top: 18rpx;
}

.block-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #231c18;
}

.species-toggle {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 8rpx;
  background: #f6f1eb;
  border-radius: 999rpx;
  width: max-content;
}

.species-toggle button {
  min-width: 96rpx;
}

.upload {
  height: 360rpx;
  background: #fff;
  border: 2rpx dashed #dbc3b1;
  border-radius: 30rpx;
  margin-top: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #9a8575;
  padding: 18rpx;
  box-sizing: border-box;
}

.secondary-upload {
  height: 220rpx;
  margin-top: 18rpx;
}

.upload image {
  width: 100%;
  height: 100%;
}

.upload > view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-plus {
  font-size: 80rpx;
  font-weight: 300;
  line-height: 1;
  color: #c9b2a0;
}

.photo-hint {
  margin-top: 12rpx;
  color: #8f7e73;
  font-size: 22rpx;
  line-height: 1.6;
}

.template-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 16rpx;
}

.template-item {
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f8ede5;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-start;
}

.template-item.on {
  background: #ff7622;
  color: #fff;
}

.template-item.on .template-hint {
  color: rgba(255, 255, 255, 0.8);
}

.template-name {
  font-size: 24rpx;
  font-weight: 800;
}

.template-hint {
  font-size: 20rpx;
  line-height: 1.5;
  color: #7c6b5f;
}

.template-summary {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff8f2;
}

.toggle {
  padding: 0 16rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: #fff;
  border: 1rpx solid #ead9ca;
}

.card textarea {
  box-sizing: border-box;
  width: 100%;
  height: 160rpx;
  background: #fff8f2;
  border-radius: 22rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  font-size: 26rpx;
}

.preview {
  height: 100%;
  min-height: 760rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #fff 0%, #fff9f2 100%);
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 30rpx;
  object-fit: cover;
}

.preview-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 24rpx;
}

.preview-title {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
  color: #231c18;
}

.preview-desc {
  margin-top: 12rpx;
  color: #8b7a6f;
  font-size: 24rpx;
  line-height: 1.7;
  max-width: 420rpx;
}

.generate {
  height: 92rpx;
  line-height: 92rpx;
  margin-top: 18rpx;
}

.ad-slot {
  margin-top: 22rpx;
}

@media (max-width: 800rpx) {
  .grid {
    grid-template-columns: 1fr;
  }

  .preview {
    min-height: 380rpx;
  }

  .template-grid {
    grid-template-columns: 1fr;
  }
}
