.page {
  min-height: 100vh;
  padding: 40rpx;
}

.card {
  padding: 36rpx;
  border-radius: 28rpx;
  background: #fff;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
}

.desc {
  display: block;
  margin: 18rpx 0 28rpx;
  color: #666;
}

.primary {
  background: #ff7a1a;
  color: #fff;
}

.result {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f7f7f7;
}
