.page {
  padding: 24rpx;
  background: #fff8ef;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #ff7622;
  font-weight: 700;
  font-size: 24rpx;
}

.title {
  margin-top: 16rpx;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.1;
}

.subtitle {
  margin-top: 16rpx;
  color: #6f6157;
  line-height: 1.8;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0e2d5;
}

.row:last-child {
  border-bottom: 0;
}

.row text,
.row view,
.notice,
.tip text {
  color: #6f6157;
  line-height: 1.8;
}

.row view {
  color: #171514;
  font-weight: 700;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.primary,
.secondary {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary {
  background: #ff7622;
  color: #fff;
}

.secondary {
  background: #fff7ef;
  color: #ff7622;
  border: 1rpx solid #ffd7b7;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
