.small{font-size:48rpx;margin-top:18rpx}.photo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin-top:38rpx}.photo{height:260rpx;border:2rpx dashed #dbc3b1;border-radius:24rpx;overflow:hidden;position:relative;background:#fff}.photo image{width:100%;height:100%}.photo>view{height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;color:#a18b7a}.photo b{font-size:56rpx;font-weight:300}.photo text{font-size:23rpx}.remove{position:absolute;right:8rpx;top:8rpx;width:48rpx;height:48rpx;border-radius:50%;background:#211a16;color:#fff;text-align:center;line-height:44rpx}.tip{margin-top:30rpx}.tip text{display:block;margin-top:12rpx;font-size:24rpx;line-height:1.7;color:#817164}.next{margin-top:34rpx;height:92rpx;line-height:92rpx}
