<view class="page">
 <text class="eyebrow">第 2 步 · 可跳过</text>
 <view class="title small">添加三张清晰照片</view>
 <view class="subtitle">建议提供正面、左侧和右侧照片，后续可用于宠物识别与 AI 写真。</view>

 <view class="photo-grid">
  <view class="photo" wx:for="{{slots}}" wx:key="label" bindtap="choose">
   <image wx:if="{{photos[index]}}" src="{{photos[index]}}" mode="aspectFill"/>
   <view wx:else>
    <text class="upload-plus">+</text>
    <text>{{item.label}}</text>
   </view>
   <text wx:if="{{photos[index]}}" class="remove" data-index="{{index}}" catchtap="remove">×</text>
  </view>
</view>

 <view class="tip card">
  <view class="block-title">照片建议</view>
  <text>光线充足、脸部无遮挡、单张主体清晰。上传页现在会同时维护本地照片和云端照片地址，为后续视觉识别与写真生成做准备。</text>
 </view>

 <view class="tip card">
  <view class="block-title">当前同步状态</view>
  <text>{{uploadMode === 'cloud' ? '云端已就绪' : uploadMode === 'syncing' ? '正在同步到云端' : '仅本地保存'}}</text>
  <text class="status-text">{{uploadMessage}}</text>
 </view>

 <button class="primary next" bindtap="next">{{photos.length ? '继续性格测试' : '跳过照片，继续测试'}}</button>
</view>
