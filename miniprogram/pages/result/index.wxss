.result-card{background:#211a16;color:#fff;border-radius:38rpx;padding:50rpx 38rpx;text-align:center}.code{font-size:30rpx;color:#ffad75;font-weight:900;letter-spacing:10rpx;margin-top:36rpx}.name{font-size:72rpx;font-weight:900;margin-top:12rpx}.en{font-size:30rpx;color:#ffd7bd;margin-top:8rpx}.desc{font-size:27rpx;line-height:1.8;color:#e5dcd6;margin-top:28rpx}.traits{display:flex;justify-content:center;gap:12rpx;margin-top:28rpx}.traits text{padding:10rpx 20rpx;border-radius:99rpx;background:#ffffff18;font-size:23rpx}.dims{margin-top:28rpx}.dim{margin-top:28rpx}.dim text{color:#ff7622;font-weight:900}.track{height:14rpx;background:#f0e2d7;border-radius:99rpx;margin-top:12rpx}.track view{height:100%;background:linear-gradient(90deg,#ffad75,#ff7622);border-radius:99rpx}.fit{text-align:right;color:#89786c;font-size:22rpx;margin-top:26rpx}.action{height:92rpx;line-height:92rpx;margin-top:22rpx}
.share-card{margin-top:28rpx}.share-card text{display:block;margin-top:16rpx;font-size:25rpx;line-height:1.8;color:#6e5f54}.share-tags{display:flex;gap:12rpx;flex-wrap:wrap;margin-top:20rpx}.share-tags text{padding:12rpx 18rpx;border-radius:99rpx;background:#fff1e6;color:#d96a19;font-size:22rpx}
