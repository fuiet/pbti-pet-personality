<view class="page" wx:if="{{record}}">
 <view class="result-card">
  <text class="eyebrow">{{record.pet.name}} 的 PBTI 性格</text>
  <view class="code">{{record.result.code}}</view>
  <view class="name">{{p.name}}</view>
  <view class="en">{{p.title}}</view>
  <view class="desc">{{p.desc}}</view>
  <view class="traits">
   <text wx:for="{{p.traits}}" wx:key="*this">{{item}}</text>
  </view>
 </view>

 <view class="card dims">
  <view class="section-title">四维性格倾向</view>
  <view class="dim" wx:for="{{dimensionRows}}" wx:key="label">
   <view class="between">
    <text class="dim-label">{{item.label}}</text>
    <text>{{item.value}}%</text>
   </view>
   <view class="track"><view style="width:{{item.value}}%"></view></view>
  </view>
  <view class="fit">原型匹配度 {{record.result.fit}}%</view>
 </view>

 <view class="card share-card" wx:if="{{sharePayload}}">
  <view class="section-title">分享摘要</view>
  <text>{{sharePayload.card.summary}}</text>
  <view class="share-tags">
   <text wx:for="{{sharePayload.card.traits}}" wx:key="*this">{{item}}</text>
  </view>
 </view>

 <view class="ad-slot">信息流广告位</view>
 <button class="primary action" bindtap="adUnlock">看广告，解锁 10 章完整报告</button>
 <button class="secondary action" bindtap="saveShareCard">生成分享卡片</button>
 <button class="secondary action" open-type="share">分享结果</button>
</view>
