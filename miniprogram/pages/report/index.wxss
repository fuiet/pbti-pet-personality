.cover{background:linear-gradient(145deg,#ff7622,#fa9a54);color:#fff;border-radius:38rpx;padding:58rpx 38rpx}
.cover text{font-size:23rpx;font-weight:900;letter-spacing:4rpx}
.cover view{font-size:70rpx;font-weight:900;margin-top:36rpx}
.cover b{display:block;font-size:30rpx;margin-top:16rpx}
.cover small{display:block;margin-top:70rpx;color:#fffbd9}
.chapter{margin-bottom:22rpx}
.chapter b{font-size:31rpx}
.chapter text{display:block;font-size:27rpx;line-height:1.9;color:#665950;margin-top:20rpx}
.line{font-size:27rpx;line-height:1.9;color:#665950;margin-top:18rpx}
.fit{font-size:24rpx;color:#d76a1a;margin-top:24rpx}
.detail-row{padding:18rpx 0;border-top:1rpx solid #efe4da}
.detail-label{display:block;font-size:24rpx;color:#9b8b7d}
.detail-value{display:block;font-size:27rpx;color:#3d342e;margin-top:8rpx}
.section-box,.tips,.action-box{margin-top:24rpx;padding:24rpx;border-radius:28rpx;background:#fff7f1}
.section-name{font-size:28rpx;font-weight:800;color:#2f2823}
.basis{margin-top:16rpx;font-size:22rpx;line-height:1.6;color:#d76a1a;background:#fff;padding:14rpx 18rpx;border-radius:18rpx}
.portrait{height:92rpx;line-height:92rpx;margin-top:22rpx}
