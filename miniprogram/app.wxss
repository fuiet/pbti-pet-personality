page{background:#fff8ef;color:#211a16;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC",sans-serif}.page{min-height:100vh;padding:36rpx;box-sizing:border-box}.card{background:#fff;border:1rpx solid #f1dfd0;border-radius:32rpx;padding:32rpx;box-shadow:0 16rpx 50rpx rgba(93,55,25,.08)}.primary{background:#ff7622!important;color:#fff!important;border:0;border-radius:999rpx;font-weight:800}.secondary{background:#fff!important;color:#5d5148!important;border:2rpx solid #ead9ca;border-radius:999rpx}.eyebrow{font-size:22rpx;font-weight:900;letter-spacing:3rpx;color:#ff7622}.title{font-size:54rpx;line-height:1.1;font-weight:900;letter-spacing:-2rpx}.subtitle{font-size:28rpx;line-height:1.7;color:#74665c}.section-title{font-size:36rpx;font-weight:900}.muted{color:#8a796c}.row{display:flex;align-items:center}.between{display:flex;align-items:center;justify-content:space-between}.pill{display:inline-block;border-radius:999rpx;background:#fff0e5;color:#e85d08;padding:10rpx 20rpx;font-size:23rpx;font-weight:800}.ad-slot{margin:28rpx 0;padding:22rpx;border:1rpx dashed #d9c4b3;border-radius:24rpx;text-align:center;color:#a28d7d;font-size:23rpx}
